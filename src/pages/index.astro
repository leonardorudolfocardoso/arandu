---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
import Section from '../components/Section.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---

<Layout
  title="Leonardo Cardoso | Backend Engineer"
  description="Backend engineer building reliable systems, APIs, and developer tools with Python, Rust, AWS, and distributed systems."
>
  <Container>

    <Section>
      <div class="hero">
        <p class="hero-label">Leonardo Cardoso</p>
        <h1 class="hero-headline">Backend engineer building reliable systems, APIs, and developer tools</h1>
        <p class="hero-lead">
          I design pragmatic software for real production constraints: asynchronous
          workflows, event-driven systems, cloud infrastructure, and developer
          experience.
        </p>
        <p class="hero-sub">
          Arandu means knowledge in Tupi-Guarani. This is where I show how I think,
          what I build, and the engineering tradeoffs behind it.
        </p>

        <div class="hero-actions">
          <a href="https://github.com/leonardorudolfocardoso" target="_blank" rel="noopener noreferrer" class="button button-primary">GitHub</a>
          <a href="https://www.linkedin.com/in/leonardo-rudolfo-cardoso-a8b420183/" target="_blank" rel="noopener noreferrer" class="button button-secondary">LinkedIn</a>
        </div>
      </div>
    </Section>

    <Section title="Selected Work">
      <div class="projects">
        {projects.map((project) => <ProjectCard {...project} />)}
      </div>
    </Section>

    <Section title="About">
      <p class="about">
        I build backend systems and developer tools with a focus on reliability,
        clarity, and real-world constraints. My recent work spans Python services,
        Rust CLIs, AWS serverless systems, and LLM-backed workflows with strong
        validation and operational discipline.
      </p>
    </Section>

    <Section title="Contact">
      <div class="contact-panel">
        <p class="contact-copy">
          If you are hiring for backend, platform, or developer tooling work, I am
          open to conversations about full-time roles and collaborative projects.
        </p>
        <div class="contact-actions">
          <a href="mailto:leonardorudolfocardoso@gmail.com" class="button button-primary">leonardorudolfocardoso@gmail.com</a>
        </div>
      </div>
    </Section>

    <footer class="footer">
      <nav class="links" aria-label="Social links">
        <a href="https://github.com/leonardorudolfocardoso" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://www.linkedin.com/in/leonardo-rudolfo-cardoso-a8b420183/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="mailto:leonardorudolfocardoso@gmail.com">Email</a>
      </nav>
      <p class="footer-copy">© 2026 Leonardo Cardoso</p>
    </footer>

  </Container>
</Layout>

<style>
  /* Hero */
  .hero {
    padding-block: 5rem 2rem;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .hero-headline {
    max-width: 12ch;
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    font-weight: 600;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .hero-lead {
    max-width: 58ch;
    font-size: 1.05rem;
    color: var(--color-text);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .hero-sub {
    max-width: 58ch;
    font-size: 0.95rem;
    color: var(--color-muted);
    line-height: 1.8;
    margin-bottom: 1.75rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 500;
    transition:
      border-color var(--transition),
      background-color var(--transition),
      color var(--transition),
      transform var(--transition);
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button-primary {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #0b0f14;
  }

  .button-primary:hover {
    background: #98f0a0;
    border-color: #98f0a0;
  }

  .button-secondary {
    color: var(--color-text);
  }

  .button-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Projects grid */
  .projects {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* About */
  .about {
    font-size: 0.98rem;
    color: var(--color-muted);
    max-width: 60ch;
    line-height: 1.8;
  }

  .contact-panel {
    display: grid;
    gap: 1rem;
    padding: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-left: 2px solid var(--color-accent);
    border-radius: 12px;
  }

  .contact-copy {
    max-width: 58ch;
    color: var(--color-muted);
    line-height: 1.8;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* Footer */
  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-block: 2rem 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .links {
    display: flex;
    gap: 2rem;
  }

  .links a {
    font-size: 0.85rem;
    color: var(--color-muted);
    transition: color var(--transition);
  }

  .links a:hover {
    color: var(--color-text);
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  @media (max-width: 640px) {
    .hero {
      padding-block: 4rem 1rem;
    }

    .hero-headline {
      max-width: none;
    }
  }
</style>
