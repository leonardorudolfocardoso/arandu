---
interface Props {
  title?: string;
  id?: string;
}

const { title, id } = Astro.props;
---

<section {id}>
  {title && <h2 class="section-title">{title}</h2>}
  <slot />
</section>

<style>
  section {
    padding-block: 3rem;
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 2rem;
  }
</style>
