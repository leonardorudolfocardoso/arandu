---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
import Section from '../components/Section.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
import AranduWordmark from '../components/AranduWordmark.astro';
---

<Layout
  title="Leonardo Cardoso | Backend Engineer"
  description="Backend engineer building reliable systems, APIs, and developer tools with Python, Rust, AWS, and distributed systems."
>
  <Container>

    <Section>
      <div class="hero">
        <div class="hero-wordmark">
          <AranduWordmark size={48} />
          <p class="hero-caption">knowledge, in Tupi-Guarani</p>
        </div>
        <h1 class="hero-headline">Building reliable<br/>backend systems,<br/>APIs, and developer tools</h1>

        <div class="hero-actions">
          <a href="#work" class="button button-primary">See my work</a>
          <a href="https://github.com/leonardorudolfocardoso" target="_blank" rel="noopener noreferrer" class="button button-secondary">GitHub</a>
        </div>
      </div>
    </Section>

    <Section title="Selected Work" id="work">
      <div class="projects">
        {projects.map((project) => <ProjectCard {...project} />)}
      </div>
    </Section>

    <Section title="About">
      <p class="about">
        I build backend systems and developer tools with a focus on reliability,
        clarity, and real-world constraints. My recent work spans Python services,
        Rust CLIs, AWS serverless systems, and LLM-backed workflows with strong
        validation and operational discipline.
      </p>
    </Section>

    <Section title="Contact">
      <div class="contact-panel">
        <p class="contact-copy">
          If you are hiring for backend, platform, or developer tooling work, I am
          open to conversations about full-time roles and collaborative projects.
        </p>
        <div class="contact-actions">
          <a href="mailto:leonardorudolfocardoso@gmail.com" class="button button-primary">leonardorudolfocardoso@gmail.com</a>
        </div>
      </div>
    </Section>

    <footer class="footer">
      <nav class="links" aria-label="Social links">
        <a href="https://github.com/leonardorudolfocardoso" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://www.linkedin.com/in/leonardo-rudolfo-cardoso-a8b420183/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="mailto:leonardorudolfocardoso@gmail.com">Email</a>
      </nav>
      <p class="footer-copy">© 2026 Leonardo Cardoso</p>
    </footer>

  </Container>
</Layout>

<style>
  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-block: 15vh 4rem;
  }

  .hero-wordmark {
    margin-bottom: 2.5rem;
  }

  .hero-caption {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-top: 0.5rem;
  }

  .hero-headline {
    max-width: 640px;
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    font-weight: 600;
    line-height: 1.1;
    color: var(--color-text);
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 500;
    transition:
      border-color var(--transition),
      background-color var(--transition),
      color var(--transition),
      transform var(--transition);
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button-primary {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #0b0f14;
  }

  .button-primary:hover {
    background: #98f0a0;
    border-color: #98f0a0;
  }

  .button-secondary {
    color: var(--color-muted);
    border-color: rgba(255, 255, 255, 0.22);
  }

  .button-secondary:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Projects grid */
  .projects {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* About */
  .about {
    font-size: 0.98rem;
    color: var(--color-muted);
    max-width: 60ch;
    line-height: 1.8;
  }

  .contact-panel {
    display: grid;
    gap: 1rem;
    padding: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-left: 2px solid var(--color-accent);
    border-radius: 12px;
  }

  .contact-copy {
    max-width: 58ch;
    color: var(--color-muted);
    line-height: 1.8;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* Footer */
  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-block: 2rem 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .links {
    display: flex;
    gap: 2rem;
  }

  .links a {
    font-size: 0.85rem;
    color: var(--color-muted);
    transition: color var(--transition);
  }

  .links a:hover {
    color: var(--color-text);
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  @media (max-width: 640px) {
    .hero {
      padding-block: 12vh 3rem;
    }

    .hero-headline {
      max-width: none;
    }
  }
</style>
